{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "walletSize": { "type": "number", "minimum": 1 },
    "maxOrderValue": { "type": "number", "minimum": 0.01 },
    "minShares": { "type": "number", "minimum": 0.000001 },
    "thesis": { "type": "string", "enum": ["inertia", "fade", "compression", "random"] },
    "entryWindowStart": { "type": "number", "minimum": 0 },
    "entryWindowEnd": { "type": "number", "minimum": 0 },
    "impulseSec": { "type": "number", "minimum": 1 },
    "volLookbackSec": { "type": "number", "minimum": 1 },
    "minShockAbs": { "type": "number", "minimum": 0 },
    "minShockZ": { "type": "number", "minimum": 0 },
    "minResponse": { "type": "number" },
    "maxResponse": { "type": "number" },
    "minOverResponse": { "type": "number" },
    "maxCompressionDist": { "type": "number", "minimum": 0.1 },
    "minCompressionVol": { "type": "number", "minimum": 0 },
    "minSignedDistance": { "type": "number" },
    "maxSignedDistance": { "type": "number" },
    "allowedPositionSide": { "type": "string", "enum": ["BOTH", "UP", "DOWN"] },
    "minAsk": { "type": "number", "minimum": 0.001, "maximum": 0.99 },
    "maxAsk": { "type": "number", "minimum": 0.001, "maximum": 0.99 },
    "maxSpread": { "type": "number", "minimum": 0.001, "maximum": 0.99 },
    "minOddsSum": { "type": "number", "minimum": 0.01, "maximum": 1.99 },
    "maxOddsSum": { "type": "number", "minimum": 0.01, "maximum": 1.99 },
    "minModelProb": { "type": "number", "minimum": 0.001, "maximum": 0.999 },
    "minModelEdge": { "type": "number", "minimum": -0.99, "maximum": 0.99 },
    "minDecisionMetric": { "type": "number", "minimum": 0 },
    "minSigma": { "type": "number", "minimum": 0.01 },
    "sigmaMultiplier": { "type": "number", "minimum": 0.1, "maximum": 5 },
    "impulseCarryWeight": { "type": "number" },
    "fadeCarryWeight": { "type": "number" },
    "carryHorizonSec": { "type": "number", "minimum": 1 },
    "carryClampSigma": { "type": "number", "minimum": 0 },
    "responseScale": { "type": "number", "minimum": 0.001 },
    "inertiaProbabilityWeight": { "type": "number", "minimum": -1, "maximum": 1 },
    "entrySlippageMax": { "type": "number", "minimum": 0, "maximum": 0.99 },
    "exitSlippageMax": { "type": "number", "minimum": 0, "maximum": 0.99 },
    "minLiquidityRatio": { "type": "number", "minimum": 0.01, "maximum": 1 },
    "exitLiquidityRatio": { "type": "number", "minimum": 0.01, "maximum": 1 },
    "fallbackBookSize": { "type": "number", "minimum": 0 },
    "takeProfitBid": { "type": "number", "minimum": 0.001, "maximum": 0.99 },
    "catchUpMinBid": { "type": "number", "minimum": 0.001, "maximum": 0.99 },
    "exitCatchUpProb": { "type": "number", "minimum": -0.99, "maximum": 0.99 },
    "stopBid": { "type": "number", "minimum": 0.001, "maximum": 0.99 },
    "stopMinBid": { "type": "number", "minimum": 0.001, "maximum": 0.99 },
    "reversalSec": { "type": "number", "minimum": 1 },
    "reversalShockAbs": { "type": "number", "minimum": 0 },
    "lateExitSec": { "type": "number", "minimum": 0 },
    "lateExitMinBid": { "type": "number", "minimum": 0.001, "maximum": 0.99 }
  }
}
