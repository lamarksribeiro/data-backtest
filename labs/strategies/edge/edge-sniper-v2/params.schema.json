{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "walletSize": { "type": "number", "minimum": 1 },
    "maxOrderValue": { "type": "number", "minimum": 1 },
    "minShares": { "type": "number", "minimum": 1 },
    "entryWindowStart": { "type": "number", "minimum": 0 },
    "entryWindowEnd": { "type": "number", "minimum": 0 },
    "minAsk": { "type": "number", "minimum": 0, "maximum": 1 },
    "maxAsk": { "type": "number", "minimum": 0, "maximum": 1 },
    "minEdge": { "type": "number" },
    "minDirectionalProb": { "type": "number", "minimum": 0, "maximum": 1 },
    "minDistanceAbs": { "type": "number", "minimum": 0 },
    "minDistanceNearExpiry": { "type": "number", "minimum": 0 },
    "nearExpiryThresholdSec": { "type": "number", "minimum": 0 },
    "minSigma": { "type": "number", "minimum": 0 },
    "sigmaMultiplier": { "type": "number", "minimum": 0 },
    "distanceWeight": { "type": "number" },
    "momentumWeight": { "type": "number" },
    "momentumSec": { "type": "number", "minimum": 0 },
    "slowMomentumSec": { "type": "number", "minimum": 0 },
    "slowMomentumWeight": { "type": "number" },
    "lagWeight": { "type": "number" },
    "volLookbackSec": { "type": "number", "minimum": 0 },
    "maxSpread": { "type": "number", "minimum": 0, "maximum": 1 },
    "entrySlippageMax": { "type": "number", "minimum": 0, "maximum": 1 },
    "minLiquidityRatio": { "type": "number", "minimum": 0 },
    "stopBid": { "type": "number", "minimum": 0, "maximum": 1 },
    "sizePriceAware": { "type": "boolean" },
    "sizePriceThreshold": { "type": "number", "minimum": 0, "maximum": 1 },
    "sizePriceFactor": { "type": "number", "minimum": 0 },
    "dynamicStopEnabled": { "type": "boolean" },
    "dynamicStopFactor": { "type": "number", "minimum": 0 },
    "dynamicStopMinBid": { "type": "number", "minimum": 0, "maximum": 1 },
    "takeProfitBid": { "type": "number", "minimum": 0, "maximum": 1 },
    "takeProfitPct": { "type": "number", "minimum": 0, "maximum": 1 },
    "trailAfterBid": { "type": "number", "minimum": 0, "maximum": 1 },
    "trailDrop": { "type": "number", "minimum": 0, "maximum": 1 },
    "lateExitSec": { "type": "number", "minimum": 0 },
    "lateExitMinBid": { "type": "number", "minimum": 0, "maximum": 1 },
    "stopReverseEnabled": { "type": "boolean" },
    "stopReverseMaxAttempts": { "type": "number", "minimum": 0 },
    "stopReverseMaxSecondsRemaining": { "type": "number", "minimum": 0 },
    "stopReverseMinSecondsRemaining": { "type": "number", "minimum": 0 },
    "stopReverseMinDistanceAbs": { "type": "number", "minimum": 0 },
    "stopReverseMaxAsk": { "type": "number", "minimum": 0, "maximum": 1 },
    "stopReverseSlippageMax": { "type": "number", "minimum": 0, "maximum": 1 },
    "stopReverseMinLiquidityRatio": { "type": "number", "minimum": 0 },
    "stopReverseBudgetMode": {
      "type": "string",
      "enum": ["same-cost", "open-cost", "sale-proceeds", "max-order"]
    },
    "stopReverseBudgetFactor": { "type": "number", "minimum": 0 },
    "useBlackScholesProb": { "type": "boolean" },
    "useObiDrift": { "type": "boolean" },
    "obiLevels": { "type": "number", "minimum": 1, "maximum": 10 },
    "obiDriftFactor": { "type": "number" },
    "driftHorizonSec": { "type": "number", "minimum": 1 },
    "useObiInScore": { "type": "boolean" },
    "obiScoreWeight": { "type": "number" }
  }
}
