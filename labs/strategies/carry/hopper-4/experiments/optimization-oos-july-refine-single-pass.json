      { "id": "fixed-cap-fok-all", "params": { "walletMaxCap": 100, "fokEnabled": true, "fokPriceCap": 0.75, "fokAteVirada": 3 } },
      { "id": "fixed-cap-cooldown55", "params": { "walletMaxCap": 100, "cooldownFlipSec": 55 } },
      { "id": "fixed-cap-trigger60", "params": { "walletMaxCap": 100, "triggerCents": 60 } },
