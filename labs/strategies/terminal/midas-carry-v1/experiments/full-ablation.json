          "sigmaSizingEnabled": false,
          "scoopEnabled": false,
          "dangerContinuousEnabled": false
        }
      },
      {
        "id": "sizing-only",
        "params": {
          "scoopEnabled": false,
          "dangerContinuousEnabled": false
        }
      },
      {
        "id": "scoop-only",
        "params": {
          "sigmaSizingEnabled": false,
          "dangerContinuousEnabled": false
        }
      },
      {
        "id": "midas-full",
        "params": {
          "dangerContinuousEnabled": false
        }
      },
      {
        "id": "midas-full-danger-cont",
        "params": {
          "dangerContinuousEnabled": true
        }
