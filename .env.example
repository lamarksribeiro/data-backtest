LAKE_ROOT=./lake
STATE_DB_PATH=./state/data-backtest.db
BACKTEST_DATA_MODE=strict
DATA_BACKTEST_PORT=3100
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_MAX_AGE_SEC=86400
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me
DATA_COLLECTOR_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/data_collector
DATA_COLLECTOR_API_URL=http://localhost:3000
DATA_COLLECTOR_ARCHIVE_API_KEY=
SYNC_BATCH_SIZE=50000
SYNC_MAX_POOL=2
SYNC_STATEMENT_TIMEOUT_MS=120000
SYNC_MARGIN_MINUTES=2
# Max relative tick-count gap vs event_quality before export is marked needs_review (0–1; default 0.02 = 2%)
SYNC_ACCEPT_COUNT_MISMATCH_RATIO=0.02
BACKTEST_BOOK_DEPTH=25

# Motor V4 (produção: soa + compiled-soa)
BACKTEST_ENGINE=soa
GLS_EXECUTION=compiled-soa
BACKTEST_WORKERS=1
MAX_CONCURRENT_BACKTESTS=1
# LRU ColumnSet; omitir = ~20% do NODE_OPTIONS heap (512–2048 MB)
DATASET_CACHE_MAX_MB=
SWEEP_MAX_VARIANTS=500
DUCKDB_THREADS=4
# Limite RAM do DuckDB em queries HTTP (ex.: 2GB)
DUCKDB_MEMORY_LIMIT=2GB
# Produção Coolify (~10 GB container): NODE_OPTIONS=--max-old-space-size=7168
